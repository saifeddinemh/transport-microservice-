# =============================================================================
# Agrofield — Variables d'environnement
# -----------------------------------------------------------------------------
# Copiez ce fichier en `.env` puis remplacez CHAQUE valeur par une valeur
# réelle. Ne JAMAIS commiter le fichier `.env` (il est ignoré par .gitignore).
# =============================================================================

# --- Environnement ------------------------------------------------------
NODE_ENV=development

# --- Base de données -----------------------------------------------------
# Chaîne de connexion PostgreSQL utilisée par Prisma.
DATABASE_URL="postgresql://username:password@localhost:5432/agrofield?schema=public"

# --- Authentification / secrets cryptographiques -------------------------
# NE JAMAIS réutiliser ces exemples en production.
# Générer une valeur forte avec : openssl rand -base64 32
SALT_ROUNDS=12
PEPPER_SECRET_KEY="changeme-generate-with-openssl-rand-base64-32"
JWT_SECRET="changeme-generate-with-openssl-rand-base64-32"

# --- Serveur HTTP ----------------------------------------------------------
HOST="0.0.0.0"
PORT=3001

# --- Sécurité réseau (CORS / rate limiting) -------------------------------
# Liste d'origines autorisées, séparées par des virgules (en plus des origines
# de développement par défaut déjà whitelistées dans src/utils/Security.ts).
CORS_ORIGIN="https://app.agrofield.example.com"
# Rate limiting global (toutes routes)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW="15 minutes"
# Rate limiting dédié aux endpoints sensibles /owner/login et /owner/register
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW="15 minutes"

# --- Kafka -----------------------------------------------------------------
# Doit pointer vers LE MÊME broker que hr-service et stock-service.
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=transport-service
KAFKA_GROUP_ID=transport-service-consumers
KAFKA_SOURCE=transport-service
KAFKA_DLQ_TOPIC=agrofield.dlq
KAFKA_MAX_RETRIES=3
KAFKA_INITIAL_DELAY_MS=250
KAFKA_BACKOFF_MULTIPLIER=2
